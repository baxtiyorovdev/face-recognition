@echo off
:: ═══════════════════════════════════════════════════
::  start_headless.bat — Фоновый запуск (Windows)
::  Двойной клик — запустится в фоне без окна
:: ═══════════════════════════════════════════════════
cd /d "%~dp0"

:: pythonw — запускает без консольного окна
:: Лог пишется в system.log
start "" /B pythonw headless.py

echo Запущено в фоне. Лог: system.log
timeout /t 3 >nul
